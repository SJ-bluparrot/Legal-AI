{
  "info": {
    "name": "Nyaay AI — Full API Suite v2",
    "description": "Complete Postman collection for the Nyaay AI FastAPI backend.\n\nBase URL defaults to localhost:8000. Change the base_url variable if your server runs elsewhere.\n\nCollection variables (auto-set by test scripts as you run requests in order):\n  base_url   → http://localhost:8000\n  api_key    → leave blank for dev (auth is skipped when API_KEY env var is unset)\n  session_id → auto-set by POST /questions\n  case_id    → auto-set by POST /intake/start\n\nRecommended order:\n  Run the '🔁 Full Flow' folder top-to-bottom for a complete happy-path walkthrough.\n  Individual folders let you test each resource in isolation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",   "value": "http://localhost:8000", "type": "string" },
    { "key": "api_key",    "value": "",                      "type": "string" },
    { "key": "session_id", "value": "",                      "type": "string" },
    { "key": "case_id",    "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "1 — Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('status=healthy', () => pm.expect(b.status).to.eql('healthy'));",
              "pm.test('api=claude',     () => pm.expect(b.api).to.eql('claude'));",
              "pm.test('has timestamp',  () => pm.expect(b.timestamp).to.be.a('string'));"
            ]}
          }]
        }
      ]
    },

    {
      "name": "2 — Chat (/questions)",
      "item": [
        {
          "name": "POST /questions — personal injury (saves session_id)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/questions" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"My client Jane Doe was hit by John Smith who ran a red light at Broadway and 34th Street Manhattan on March 10 2025. She has a broken leg and $15,000 in medical bills.\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('has answer',          () => pm.expect(b.answer).to.be.a('string').and.not.empty);",
              "pm.test('has session_id',      () => pm.expect(b.session_id).to.be.a('string').and.not.empty);",
              "pm.test('has case_type',       () => pm.expect(b.case_type).to.be.a('string'));",
              "pm.test('has offer_complaint', () => pm.expect(b.offer_complaint).to.be.a('boolean'));",
              "pm.test('has required_elements', () => pm.expect(b.required_elements).to.be.an('array'));",
              "pm.collectionVariables.set('session_id', b.session_id);",
              "console.log('session_id saved:', b.session_id, '| case_type:', b.case_type, '| offer_complaint:', b.offer_complaint);"
            ]}
          }]
        },
        {
          "name": "POST /questions — follow-up (same session)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/questions" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"John Smith was driving a blue Toyota Camry, plate ABC-1234. Jane received treatment at Bellevue Hospital.\",\n  \"session_id\": \"{{session_id}}\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('same session_id', () => pm.expect(b.session_id).to.eql(pm.collectionVariables.get('session_id')));",
              "console.log('offer_complaint:', b.offer_complaint, '| case_type:', b.case_type);"
            ]}
          }]
        },
        {
          "name": "POST /questions — employment dispute",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/questions" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"My client Marcus Lee was fired from Acme Corp in New York last week after he reported wage theft to HR. He had been a software engineer there since 2021 earning $95,000 per year.\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('classified as employment', () => pm.expect(b.case_type).to.eql('employment_dispute'));"
            ]}
          }]
        },
        {
          "name": "POST /questions — ❌ empty question (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/questions" },
            "body": { "mode": "raw", "raw": "{\n  \"question\": \"   \"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('422 Unprocessable Entity', () => pm.response.to.have.status(422));"
            ]}
          }]
        },
        {
          "name": "POST /questions — ❌ non-NY jurisdiction (soft block)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/questions" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"I was in a car accident in California last week. What are my options?\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK (soft block — answer explains NY-only)', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('case_type=unsupported',  () => pm.expect(b.case_type).to.eql('unsupported'));",
              "pm.test('offer_complaint=false',   () => pm.expect(b.offer_complaint).to.be.false);"
            ]}
          }]
        },
        {
          "name": "POST /questions — ❌ missing question field (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/questions" },
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('422 Unprocessable Entity', () => pm.response.to.have.status(422));"
            ]}
          }]
        }
      ]
    },

    {
