              "pm.test('404 Not Found', () => pm.response.to.have.status(404));"
            ]}
          }]
        },
        {
          "name": "POST /history/{session_id}/clear",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/history/{{session_id}}/clear" }
          },
          "event": [{
            "listen": "test",
