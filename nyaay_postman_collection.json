          "name": "DELETE /sessions/{session_id}",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/sessions/{{session_id}}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));",
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('session_id', '');",
              "  console.log('Session deleted and session_id cleared.');",
              "}"
            ]}
          }]
        }
      ]
    },

    {
      "name": "4 — Intake",
      "description": "All intake endpoints require Authorization: Bearer {{api_key}} in production. In dev mode (API_KEY env var unset), auth is skipped.",
      "item": [
        {
          "name": "POST /intake/start — personal_injury (saves case_id)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}", "description": "Required in production. Leave blank for dev." }
            ],
            "url": { "raw": "{{base_url}}/intake/start" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"case_type\": \"personal_injury\",\n  \"initial_text\": \"Jane Doe was hit by John Smith who ran a red light at Broadway and 34th Street Manhattan on March 10 2025. She has a broken leg and $15,000 in medical bills. She was treated at Bellevue Hospital.\"\n}"
            }
          },
          "event": [
          {
            "listen": "prerequest",
            "script": { "exec": [
              "const sid = pm.collectionVariables.get('session_id');",
              "if (!sid) {",
              "  console.warn('⚠️  session_id not set. Run \"POST /questions — personal injury\" first.');",
              "}"
            ]}
          },
          {
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('has case_id',         () => pm.expect(b.case_id).to.be.a('string').and.not.empty);",
              "pm.test('has case_type',        () => pm.expect(b.case_type).to.eql('personal_injury'));",
              "pm.test('has is_complete',      () => pm.expect(b.is_complete).to.be.a('boolean'));",
              "pm.test('has pre_filled',       () => pm.expect(b.pre_filled).to.be.an('object'));",
              "pm.test('has missing_required', () => pm.expect(b.missing_required).to.be.an('array'));",
              "pm.test('has missing_questions',() => pm.expect(b.missing_questions).to.be.an('array'));",
              "pm.test('has sections_display', () => pm.expect(b.sections_display).to.be.an('object'));",
              "pm.test('has validation',       () => pm.expect(b.validation).to.be.an('object'));",
              "pm.test('validation has draft_readiness_score', () => pm.expect(b.validation.draft_readiness_score).to.be.a('number'));",
              "pm.collectionVariables.set('case_id', b.case_id);",
              "console.log('case_id saved:', b.case_id);",
              "console.log('pre_filled keys:', Object.keys(b.pre_filled));",
              "console.log('missing_required count:', b.missing_required.length);",
              "console.log('readiness score:', b.validation.draft_readiness_score + '%');"
            ]}
          }
          ]
        },
        {
          "name": "POST /intake/start — ❌ invalid case_type (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": { "raw": "{{base_url}}/intake/start" },
            "body": {
              "mode": "raw",
