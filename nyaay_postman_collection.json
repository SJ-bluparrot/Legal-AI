    {
      "name": "5 — Draft Complaint (Claude Sonnet)",
      "description": "Requires Authorization: Bearer {{api_key}} in production.",
      "item": [
        {
          "name": "POST /draft/{case_id} — generate complaint",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": { "raw": "{{base_url}}/draft/{{case_id}}" },
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('has complaint text', () => pm.expect(b.complaint).to.be.a('string').and.not.empty);",
              "pm.test('has word_count',     () => pm.expect(b.word_count).to.be.a('number').and.above(0));",
              "pm.test('has unknown_count',  () => pm.expect(b.unknown_count).to.be.a('number'));",
              "pm.test('has from_cache',     () => pm.expect(b.from_cache).to.be.a('boolean'));",
              "pm.test('has case_type',      () => pm.expect(b.case_type).to.be.a('string'));",
              "console.log('words:', b.word_count, '| [UNKNOWN] placeholders:', b.unknown_count, '| from_cache:', b.from_cache);",
              "if (b.unknown_count > 0) {",
              "  console.warn('⚠️  Complaint has', b.unknown_count, '[UNKNOWN] placeholder(s). Missing fields should be filled before filing.');",
              "}"
            ]}
          }]
        },
        {
          "name": "POST /draft/{case_id} — re-request (returns from cache)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": { "raw": "{{base_url}}/draft/{{case_id}}" },
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 OK',           () => pm.response.to.have.status(200));",
              "pm.test('served from cache',() => pm.expect(pm.response.json().from_cache).to.be.true);",
              "console.log('Draft served from cache — no Claude API call made.');"
            ]}
          }]
        },
        {
          "name": "GET /draft/{case_id} — retrieve cached draft",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "url": { "raw": "{{base_url}}/draft/{{case_id}}" }
          },
          "event": [{
