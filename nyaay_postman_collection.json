              "console.log('is_complete:', b.is_complete, '| can_draft:', b.validation.can_draft, '| readiness:', b.validation.draft_readiness_score);"
            ]}
          }]
        },
        {
          "name": "POST /intake/{case_id}/provide — ❌ empty text (422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
